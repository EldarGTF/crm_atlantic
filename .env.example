# Database
DATABASE_URL="postgresql://user:password@localhost:5432/crm_atlantic"

# Session (min 32 chars in production)
SESSION_SECRET="change-me-to-a-random-string-at-least-32-characters"

# Файлы: Supabase (облако) ИЛИ S3/MinIO (VPS) — достаточно одного варианта

# Supabase (Vercel / облако)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# MinIO / S3 (VPS, см. docs/DEPLOY-VPS-KZ.md)
# S3_ENDPOINT="http://minio:9000"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET="crm-files"
# S3_PUBLIC_URL="https://crm.example.kz/files"

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@example.com"

# Mobizon SMS
MOBIZON_API_KEY=""
MOBIZON_SENDER=""
MOBIZON_DOMAIN=""

# Bootstrap admin (scripts/create-admin.ts)
ADMIN_EMAIL="admin@atlantic.kz"
ADMIN_PASSWORD=""
