# Скопируйте на сервер: cp .env.vps.example .env

# --- PostgreSQL ---
POSTGRES_USER=crm
POSTGRES_PASSWORD=замените_на_длинный_пароль
POSTGRES_DB=crm_atlantic

# --- MinIO (файлы) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=замените_на_длинный_пароль
# Публичный URL файлов (ваш домен + /files)
S3_PUBLIC_URL=https://crm.ваш-домен.kz/files

# --- Приложение ---
SESSION_SECRET=минимум_32_случайных_символа_для_jwt
HTTP_PORT=80
# Пока нет HTTPS — обязательно false (иначе выкидывает на логин при переходах)
COOKIE_SECURE=false

# --- SMS Mobizon ---
MOBIZON_API_KEY=
MOBIZON_SENDER=
MOBIZON_DOMAIN=api.mobizon.kz

# --- Web Push (опционально) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@atlantic.kz

# --- Первый админ (для docker compose run) ---
ADMIN_EMAIL=admin@atlantic.kz
ADMIN_PASSWORD=admin123
