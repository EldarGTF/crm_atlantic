generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Роли ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  MEASURER
  INSTALLER
  PRODUCTION
  PRODUCTION_GLASS
  PRODUCTION_PVC
  PRODUCTION_ALUMINUM
  ECONOMIST
}

enum ProductionDept {
  GLASS
  PVC
  ALUMINUM
}

// ─── Пользователи ────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(MANAGER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads             Lead[]
  measurements      Measurement[]
  tasks             Task[]             @relation("TaskAssignee")
  tasksCreated      Task[]             @relation("TaskCreator")
  installations     Installation[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// ─── Клиенты ─────────────────────────────────────────────────────────────────

enum ClientStatus {
  REGULAR
  RETURNING
  VIP
}

model Client {
  id        String       @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  status    ClientStatus @default(REGULAR)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  leads  Lead[]
  orders Order[]

  @@map("clients")
}

// ─── Заявки ──────────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  IN_PROGRESS
  MEASUREMENT_SCHEDULED
  MEASUREMENT_DONE
  QUOTE_SENT
  AGREED
  SENT_TO_PRODUCTION
  IN_PRODUCTION
  READY_FOR_INSTALLATION
  INSTALLATION_SCHEDULED
  INSTALLED
  ACT_SIGNED
  CLOSED
  CANCELLED
}

enum LeadSource {
  CALL
  WEBSITE
  INSTAGRAM
  REFERRAL
  REPEAT
  OTHER
}

model Lead {
  id          String     @id @default(cuid())
  clientId    String
  managerId   String
  source      LeadSource @default(CALL)
  status      LeadStatus @default(NEW)
  description String?
  archived    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  client        Client        @relation(fields: [clientId], references: [id])
  manager       User          @relation(fields: [managerId], references: [id])
  statusHistory LeadHistory[]
  measurements  Measurement[]
  order         Order?
  tasks         Task[]

  @@map("leads")
}

model LeadHistory {
  id        String     @id @default(cuid())
  leadId    String
  status    LeadStatus
  note      String?
  createdAt DateTime   @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_history")
}

// ─── Замеры ───────────────────────────────────────────────────────────────────

model Measurement {
  id          String    @id @default(cuid())
  leadId      String
  measurerId  String
  scheduledAt DateTime
  inWorkAt    DateTime?
  doneAt      DateTime?
  address     String
  notes       String?
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead     Lead              @relation(fields: [leadId], references: [id])
  measurer User              @relation(fields: [measurerId], references: [id])
  files    MeasurementFile[]

  @@map("measurements")
}

model MeasurementFile {
  id            String   @id @default(cuid())
  measurementId String
  name          String
  url           String
  size          Int
  createdAt     DateTime @default(now())

  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Cascade)

  @@map("measurement_files")
}

// ─── Заказы ───────────────────────────────────────────────────────────────────

enum PaymentStatus {
  UNPAID
  PREPAID
  PAID
}

model Order {
  id                   String        @id @default(cuid())
  leadId               String        @unique
  clientId             String
  totalAmount          Decimal       @db.Decimal(12, 2)
  prepaidAmount        Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus        PaymentStatus @default(UNPAID)
  installationIncluded Boolean       @default(true)
  installationCost     Decimal       @default(0) @db.Decimal(12, 2)
  productionDeadline   DateTime?
  notes                String?
  archived             Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  lead            Lead                  @relation(fields: [leadId], references: [id])
  client          Client                @relation(fields: [clientId], references: [id])
  items           OrderItem[]
  extraWorks      ExtraWork[]
  payments        Payment[]
  files           OrderFile[]
  installation    Installation?
  act             Act?
  productionDepts OrderProductionDept[]

  @@map("orders")
}

// ─── Цехи производства ────────────────────────────────────────────────────────

model OrderProductionDept {
  id        String         @id @default(cuid())
  orderId   String
  dept      ProductionDept
  inWorkAt  DateTime?
  doneAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, dept])
  @@map("order_production_depts")
}

// ─── Позиции заказа (спецификация) ───────────────────────────────────────────

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productType String
  profile     String?
  width       Int
  height      Int
  config      String?
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)
  notes       String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ─── Дополнительные работы ────────────────────────────────────────────────────

model ExtraWork {
  id      String  @id @default(cuid())
  orderId String
  name    String
  price   Decimal @db.Decimal(12, 2)
  notes   String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("extra_works")
}

// ─── Оплаты ──────────────────────────────────────────────────────────────────

enum PaymentType {
  PREPAYMENT
  FINAL
  OTHER
}

model Payment {
  id      String      @id @default(cuid())
  orderId String
  amount  Decimal     @db.Decimal(12, 2)
  type    PaymentType
  paidAt  DateTime    @default(now())
  notes   String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Файлы заказа ────────────────────────────────────────────────────────────

enum OrderFileType {
  DOCUMENT
  PRODUCTION
  INSTALLATION
  OTHER
  WORK_ORDER_GLASS
  WORK_ORDER_PVC
  WORK_ORDER_ALUMINUM
  MATERIALS_LIST
}

model OrderFile {
  id        String        @id @default(cuid())
  orderId   String
  type      OrderFileType @default(DOCUMENT)
  name      String
  url       String
  size      Int
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_files")
}

// ─── Монтаж ───────────────────────────────────────────────────────────────────

model Installation {
  id          String    @id @default(cuid())
  orderId     String    @unique
  installerId String
  scheduledAt DateTime
  inWorkAt    DateTime?
  doneAt      DateTime?
  address     String
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  order     Order @relation(fields: [orderId], references: [id])
  installer User  @relation(fields: [installerId], references: [id])

  @@map("installations")
}

// ─── Акт выполненных работ ───────────────────────────────────────────────────

model Act {
  id        String   @id @default(cuid())
  orderId   String   @unique
  signedAt  DateTime
  fileUrl   String?
  notes     String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("acts")
}

// ─── Push-подписки ───────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── Задачи ───────────────────────────────────────────────────────────────────

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  assigneeId  String
  creatorId   String
  leadId      String?
  dueAt       DateTime?
  status      TaskStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  assignee User  @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User  @relation("TaskCreator", fields: [creatorId], references: [id])
  lead     Lead? @relation(fields: [leadId], references: [id])

  @@map("tasks")
}
